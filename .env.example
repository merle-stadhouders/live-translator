# Copy this file to a new file called ".env" and paste your real keys below.
# (The .env file is ignored by git, so your keys stay private.)

# Get this from https://elevenlabs.io  ->  your profile  ->  API Keys
ELEVENLABS_API_KEY=your-elevenlabs-key-here

# Get this from https://console.anthropic.com  ->  API Keys
ANTHROPIC_API_KEY=your-anthropic-key-here
